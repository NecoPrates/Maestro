<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Maestro Prompt Builder</title>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@2.44.0/tabler-icons.min.css" />
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#fff;--bg2:#f7f7f5;--bg3:#f0efe8;
  --text:#1a1a1a;--text2:#6b6b6b;--text3:#aaa;
  --border:rgba(0,0,0,.12);--border2:rgba(0,0,0,.22);
  --info-bg:#e8f0fd;--info-text:#1a4fc4;
  --success-bg:#eaf3de;--success-text:#3b6d11;
  --danger-text:#a32d2d;
  --radius:8px;--radius-lg:12px;
}
@media(prefers-color-scheme:dark){
  :root{
    --bg:#1e1e1e;--bg2:#2a2a2a;--bg3:#333;
    --text:#f0f0f0;--text2:#aaa;--text3:#666;
    --border:rgba(255,255,255,.12);--border2:rgba(255,255,255,.22);
    --info-bg:#1a2a4a;--info-text:#7eaaff;
    --success-bg:#173404;--success-text:#97c459;
    --danger-text:#f09595;
  }
}
body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;background:var(--bg3);color:var(--text);min-height:100vh;padding:1.5rem}
h1{font-size:20px;font-weight:500;margin-bottom:1.5rem;display:flex;align-items:center;gap:10px}
.badge{font-size:12px;font-weight:500;padding:3px 10px;border-radius:20px;background:var(--info-bg);color:var(--info-text);letter-spacing:.04em}
.app{display:grid;grid-template-columns:1fr 300px;gap:1rem;max-width:1100px;margin:0 auto}
@media(max-width:700px){.app{grid-template-columns:1fr}}
.card{background:var(--bg);border-radius:var(--radius-lg);border:0.5px solid var(--border);padding:1.25rem}
.progress{display:flex;gap:3px;margin-bottom:1rem}
.prog-seg{height:3px;flex:1;border-radius:2px;background:var(--border);transition:background .3s}
.prog-seg.done{background:var(--text)}
.steps{display:flex;gap:5px;margin-bottom:1.25rem;flex-wrap:wrap}
.step-btn{padding:5px 11px;font-size:12px;border-radius:20px;border:0.5px solid var(--border2);background:transparent;cursor:pointer;color:var(--text2);transition:all .15s;white-space:nowrap;font-family:inherit}
.step-btn.active{background:var(--text);color:var(--bg);border-color:var(--text)}
.step-btn.filled{border-color:var(--success-text);color:var(--success-text)}
.step-panel{display:none}
.step-panel.active{display:block}
.step-letter{font-size:28px;font-weight:500;line-height:1}
.step-name{font-size:14px;color:var(--text2);margin-top:2px}
.step-question{font-size:12.5px;color:var(--text3);margin-top:3px;font-style:italic}
.step-header{margin-bottom:1rem}
label{display:block;font-size:11px;font-weight:500;color:var(--text2);margin-bottom:4px;text-transform:uppercase;letter-spacing:.04em}
input,select,textarea{width:100%;padding:8px 10px;border:0.5px solid var(--border);border-radius:var(--radius);background:var(--bg);color:var(--text);font-family:inherit;font-size:13.5px;outline:none;transition:border .15s}
input:focus,select:focus,textarea:focus{border-color:var(--border2)}
textarea{resize:vertical}
.field{margin-bottom:.85rem}
.hint{font-size:11px;color:var(--text3);margin-top:4px}
.chips{display:flex;flex-wrap:wrap;gap:5px;margin-top:5px}
.chip{padding:4px 10px;font-size:12px;border:0.5px solid var(--border);border-radius:20px;cursor:pointer;background:transparent;color:var(--text2);font-family:inherit;transition:all .12s}
.chip:hover{background:var(--bg2)}
.chip.sel{background:var(--text);color:var(--bg);border-color:var(--text)}
.nav-row{display:flex;gap:8px;align-items:center;margin-top:1rem;padding-top:.75rem;border-top:0.5px solid var(--border)}
.btn{padding:7px 16px;font-size:13px;border-radius:var(--radius);cursor:pointer;font-family:inherit;font-weight:500;transition:opacity .15s,transform .1s}
.btn:active{transform:scale(.97)}
.btn-primary{background:var(--text);color:var(--bg);border:none}
.btn-primary:hover{opacity:.85}
.btn-primary:disabled{opacity:.4;cursor:not-allowed}
.btn-secondary{background:transparent;color:var(--text);border:0.5px solid var(--border2)}
.btn-secondary:hover{background:var(--bg2)}
.btn-sm{padding:5px 12px;font-size:12px}
.step-lbl{font-size:11px;color:var(--text3);margin-left:auto}
.summary-grid{display:grid;grid-template-columns:1fr 1fr;gap:7px;margin-bottom:1rem}
.s-cell{background:var(--bg2);border-radius:var(--radius);padding:8px 10px}
.s-cell-label{font-size:10px;font-weight:500;color:var(--text3);text-transform:uppercase;letter-spacing:.04em}
.s-cell-val{font-size:12px;color:var(--text);margin-top:2px;line-height:1.4}
.result-area{margin-top:1rem;border-top:0.5px solid var(--border);padding-top:1rem;display:none}
.result-area.show{display:block}
.result-lbl{font-size:11px;font-weight:500;color:var(--text2);margin-bottom:6px;text-transform:uppercase;letter-spacing:.04em}
.result-box{font-size:13px;line-height:1.75;white-space:pre-wrap;padding:12px;border:0.5px solid var(--border);border-radius:var(--radius);background:var(--bg2);min-height:80px;color:var(--text)}
.status{font-size:12px;margin-top:6px;min-height:16px}
.status.ok{color:var(--success-text)}
.status.err{color:var(--danger-text)}
.status.loading{color:var(--info-text)}
.result-actions{display:flex;gap:6px;margin-top:8px;flex-wrap:wrap}
.sidebar-title{font-size:14px;font-weight:500;margin-bottom:.75rem;display:flex;justify-content:space-between;align-items:center}
.lib-count{font-size:11px;color:var(--text3)}
.pcard{background:var(--bg);border:0.5px solid var(--border);border-radius:var(--radius);padding:10px;margin-bottom:8px}
.pcard:hover{border-color:var(--border2)}
.pcard-top{display:flex;align-items:center;gap:6px;margin-bottom:4px}
.pcard-name{font-size:13px;font-weight:500;flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.cat-badge{font-size:10px;padding:2px 7px;border-radius:10px;background:var(--info-bg);color:var(--info-text);white-space:nowrap}
.pcard-preview{font-size:11.5px;color:var(--text2);overflow:hidden;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;line-height:1.5}
.pcard-actions{display:flex;gap:5px;margin-top:7px}
.mini{padding:3px 8px;font-size:11px;border-radius:4px;cursor:pointer;border:0.5px solid var(--border);background:transparent;color:var(--text2);font-family:inherit}
.mini:hover{background:var(--bg2);border-color:var(--border2)}
.mini.danger:hover{color:var(--danger-text)}
.empty{text-align:center;padding:2rem 1rem;font-size:12px;color:var(--text3)}
.modal-bg{display:none;position:fixed;inset:0;background:rgba(0,0,0,.4);z-index:100;align-items:center;justify-content:center}
.modal-bg.open{display:flex}
.modal{background:var(--bg);border-radius:var(--radius-lg);border:0.5px solid var(--border);padding:1.5rem;width:90%;max-width:520px;max-height:80vh;display:flex;flex-direction:column}
.modal h3{font-size:15px;font-weight:500;margin-bottom:.75rem}
.modal-body{font-size:13px;line-height:1.75;white-space:pre-wrap;overflow-y:auto;border:0.5px solid var(--border);border-radius:var(--radius);padding:12px;background:var(--bg2);flex:1}
.modal-foot{display:flex;gap:6px;margin-top:.75rem;justify-content:flex-end}
.spinner{display:inline-block;width:11px;height:11px;border:2px solid var(--border);border-top-color:var(--text);border-radius:50%;animation:spin .6s linear infinite;vertical-align:-1px;margin-right:4px}
@keyframes spin{to{transform:rotate(360deg)}}
.api-notice{background:var(--info-bg);color:var(--info-text);font-size:12px;padding:10px 14px;border-radius:var(--radius);margin-bottom:1rem;line-height:1.5}
</style>
</head>
<body>
<h1>
  <i class="ti ti-wand"></i> Maestro Prompt Builder
  <span class="badge">M · A · E · S · T · R · O</span>
</h1>

<div class="api-notice">
  <strong>⚠️ Nota:</strong> Para usar a geração com IA, este arquivo precisa ser aberto dentro do Claude.ai ou a função "Gerar com Claude" ficará indisponível. A biblioteca local funciona normalmente em qualquer navegador.
</div>

<div class="app">
  <div class="card">
    <div class="progress" id="progress-bar">
      <div class="prog-seg" id="p0"></div><div class="prog-seg" id="p1"></div>
      <div class="prog-seg" id="p2"></div><div class="prog-seg" id="p3"></div>
      <div class="prog-seg" id="p4"></div><div class="prog-seg" id="p5"></div>
      <div class="prog-seg" id="p6"></div>
    </div>
    <div class="steps">
      <button class="step-btn active" onclick="goStep(0)" id="stab0">M — Missão</button>
      <button class="step-btn" onclick="goStep(1)" id="stab1">A — Ator</button>
      <button class="step-btn" onclick="goStep(2)" id="stab2">E — Estilo</button>
      <button class="step-btn" onclick="goStep(3)" id="stab3">S — Situação</button>
      <button class="step-btn" onclick="goStep(4)" id="stab4">T — Tarefas</button>
      <button class="step-btn" onclick="goStep(5)" id="stab5">R — Restrições</button>
      <button class="step-btn" onclick="goStep(6)" id="stab6">O — Output</button>
    </div>

    <!-- M -->
    <div class="step-panel active" id="sp0">
      <div class="step-header"><div class="step-letter">M</div><div class="step-name">Missão</div><div class="step-question">O que você quer alcançar?</div></div>
      <div class="field"><label>Nome do prompt</label><input type="text" id="f-nome" placeholder="Ex: Email de prospecção B2B" /></div>
      <div class="field"><label>Categoria</label><select id="f-cat"><option>Conteúdo</option><option>Comunicação</option><option>Análise</option><option>Código</option><option>Estratégia</option><option>Educação</option><option>Outro</option></select></div>
      <div class="field"><label>Objetivo principal</label><textarea id="f-missao" rows="3" placeholder="Ex: Convencer meu chefe a aprovar o orçamento do projeto"></textarea><div class="hint">Pense no resultado final, não na tarefa em si.</div></div>
      <div class="chips">
        <button class="chip" onclick="addChip('f-missao',this)">Convencer stakeholders</button>
        <button class="chip" onclick="addChip('f-missao',this)">Conseguir uma promoção</button>
        <button class="chip" onclick="addChip('f-missao',this)">Fazer o cliente responder</button>
        <button class="chip" onclick="addChip('f-missao',this)">Tornar a apresentação memorável</button>
        <button class="chip" onclick="addChip('f-missao',this)">Reter um funcionário</button>
        <button class="chip" onclick="addChip('f-missao',this)">Fazer o currículo passar pelo RH</button>
      </div>
    </div>

    <!-- A -->
    <div class="step-panel" id="sp1">
      <div class="step-header"><div class="step-letter">A</div><div class="step-name">Ator</div><div class="step-question">Quem a IA deve ser? (persona)</div></div>
      <div class="field"><label>Persona da IA</label><input type="text" id="f-ator" placeholder="Ex: Consultor de estratégia da McKinsey" /><div class="hint">Quanto mais específica a persona, mais precisa será a resposta.</div></div>
      <div class="chips">
        <button class="chip" onclick="setField('f-ator',this)">Consultor McKinsey</button>
        <button class="chip" onclick="setField('f-ator',this)">Professor universitário</button>
        <button class="chip" onclick="setField('f-ator',this)">Copywriter de resposta direta</button>
        <button class="chip" onclick="setField('f-ator',this)">CFO de multinacional</button>
        <button class="chip" onclick="setField('f-ator',this)">Coach de carreira</button>
        <button class="chip" onclick="setField('f-ator',this)">Jornalista investigativo</button>
        <button class="chip" onclick="setField('f-ator',this)">Designer de UX</button>
        <button class="chip" onclick="setField('f-ator',this)">Advogado corporativo</button>
        <button class="chip" onclick="setField('f-ator',this)">Mentor de startup</button>
        <button class="chip" onclick="setField('f-ator',this)">Recrutador sênior big tech</button>
      </div>
    </div>

    <!-- E -->
    <div class="step-panel" id="sp2">
      <div class="step-header"><div class="step-letter">E</div><div class="step-name">Estilo</div><div class="step-question">Qual tom e nível de profundidade?</div></div>
      <div class="field"><label>Tom de comunicação</label><select id="f-tom"><option value="">— selecionar —</option><option>Formal</option><option>Informal</option><option>Técnico</option><option>Didático</option><option>Inspirador</option><option>Direto</option><option>Empático</option><option>Provocativo</option><option>Assertivo</option><option>Consultivo</option><option>Storytelling</option></select></div>
      <div class="field"><label>Instrução de estilo personalizada</label><input type="text" id="f-estilo-custom" placeholder='Ex: "Tom de TED Talk, que motive ação"' /><div class="hint">Ex: "Escreva como se fosse um Slack para colega" · "Vá direto ao ponto, sem introduções"</div></div>
      <div class="field"><label>Nível de profundidade</label><select id="f-nivel"><option value="">— selecionar —</option><option>Básico — iniciante no tema</option><option>Intermediário — algum conhecimento</option><option>Avançado — especialista na área</option><option>Executivo — síntese para decisão rápida</option></select></div>
    </div>

    <!-- S -->
    <div class="step-panel" id="sp3">
      <div class="step-header"><div class="step-letter">S</div><div class="step-name">Situação</div><div class="step-question">Qual o contexto?</div></div>
      <div class="field"><label>Descreva o contexto relevante</label><textarea id="f-situacao" rows="4" placeholder="Inclua contexto sobre você, a empresa, o decisor, o momento..."></textarea></div>
      <div class="chips">
        <button class="chip" onclick="addChip('f-situacao',this)">Sobre mim: [cargo/experiência]</button>
        <button class="chip" onclick="addChip('f-situacao',this)">Sobre a empresa: [tamanho/setor]</button>
        <button class="chip" onclick="addChip('f-situacao',this)">Sobre o decisor: [perfil]</button>
        <button class="chip" onclick="addChip('f-situacao',this)">Sobre o momento: [urgência]</button>
        <button class="chip" onclick="addChip('f-situacao',this)">Tentativas anteriores: [o que não funcionou]</button>
      </div>
    </div>

    <!-- T -->
    <div class="step-panel" id="sp4">
      <div class="step-header"><div class="step-letter">T</div><div class="step-name">Tarefas</div><div class="step-question">Quais passos específicos?</div></div>
      <div class="field"><label>Instruções específicas de execução</label><textarea id="f-tarefas" rows="4" placeholder="Ex:&#10;1. Liste os 3 principais riscos&#10;2. Simule as objeções possíveis&#10;3. Sugira uma resposta para cada"></textarea></div>
      <div class="chips">
        <button class="chip" onclick="addChip('f-tarefas',this)">Analise os principais riscos</button>
        <button class="chip" onclick="addChip('f-tarefas',this)">Compare as opções A e B</button>
        <button class="chip" onclick="addChip('f-tarefas',this)">Simule objeções e respostas</button>
        <button class="chip" onclick="addChip('f-tarefas',this)">Resuma em 3 bullets</button>
        <button class="chip" onclick="addChip('f-tarefas',this)">Faça o advogado do diabo</button>
        <button class="chip" onclick="addChip('f-tarefas',this)">Sugira KPIs para medir</button>
      </div>
    </div>

    <!-- R -->
    <div class="step-panel" id="sp5">
      <div class="step-header"><div class="step-letter">R</div><div class="step-name">Restrições</div><div class="step-question">O que evitar? Quais limites?</div></div>
      <div class="field"><label>Defina as restrições</label><textarea id="f-restricoes" rows="4" placeholder="Ex: Não use jargões técnicos. Máximo 200 palavras. Evite tom agressivo."></textarea></div>
      <div class="chips">
        <button class="chip" onclick="addChip('f-restricoes',this)">Sem jargões técnicos</button>
        <button class="chip" onclick="addChip('f-restricoes',this)">Máximo 200 palavras</button>
        <button class="chip" onclick="addChip('f-restricoes',this)">Sem introduções longas</button>
        <button class="chip" onclick="addChip('f-restricoes',this)">Não mencionar concorrentes</button>
        <button class="chip" onclick="addChip('f-restricoes',this)">Sem usar clichês</button>
      </div>
    </div>

    <!-- O -->
    <div class="step-panel" id="sp6">
      <div class="step-header"><div class="step-letter">O</div><div class="step-name">Output</div><div class="step-question">Qual formato da entrega?</div></div>
      <div class="field"><label>Formato de saída</label><select id="f-formato"><option value="">— selecionar —</option><option>Texto corrido</option><option>Lista com marcadores</option><option>Passo a passo numerado</option><option>Tabela</option><option>Email estruturado</option><option>Roteiro</option><option>Código</option><option>JSON</option></select></div>
      <div class="field"><label>Detalhes do output</label><input type="text" id="f-output-detail" placeholder='Ex: "3 opções com prós e contras de cada"' /></div>
      <div class="field"><label>Resumo — revise antes de gerar</label><div class="summary-grid" id="summary-grid"></div></div>
      <div style="display:flex;gap:8px;flex-wrap:wrap">
        <button class="btn btn-primary" id="btn-gen" onclick="generatePrompt()"><i class="ti ti-sparkles"></i> Gerar com Claude ↗</button>
        <button class="btn btn-secondary" onclick="saveRaw()"><i class="ti ti-device-floppy"></i> Salvar estrutura</button>
      </div>
      <div class="status" id="gen-status"></div>
    </div>

    <div class="result-area" id="result-area">
      <div class="result-lbl">Prompt gerado</div>
      <div class="result-box" id="result-box"></div>
      <div class="result-actions">
        <button class="btn btn-primary btn-sm" onclick="saveGenerated()"><i class="ti ti-device-floppy"></i> Salvar na biblioteca</button>
        <button class="btn btn-secondary btn-sm" onclick="copyResult()"><i class="ti ti-copy"></i> Copiar</button>
      </div>
    </div>

    <div class="nav-row">
      <button class="btn btn-secondary btn-sm" onclick="prevStep()" id="btn-prev" style="display:none"><i class="ti ti-arrow-left"></i> Anterior</button>
      <button class="btn btn-primary btn-sm" onclick="nextStep()" id="btn-next">Próximo <i class="ti ti-arrow-right"></i></button>
      <span class="step-lbl" id="step-label">1 / 7</span>
    </div>
  </div>

  <div>
    <div class="card">
      <div class="sidebar-title">
        <span><i class="ti ti-database" style="vertical-align:-2px;margin-right:4px"></i>Biblioteca</span>
        <span class="lib-count" id="lib-count">0 prompts</span>
      </div>
      <div class="field"><input type="text" id="lib-search" placeholder="Buscar..." style="font-size:12.5px" oninput="renderLib()" /></div>
      <div id="lib-list"></div>
    </div>
  </div>
</div>

<div class="modal-bg" id="modal">
  <div class="modal">
    <h3 id="modal-title">Prompt</h3>
    <div class="modal-body" id="modal-body"></div>
    <div class="modal-foot">
      <button class="btn btn-secondary btn-sm" onclick="copyModal()"><i class="ti ti-copy"></i> Copiar</button>
      <button class="btn btn-secondary btn-sm" onclick="closeModal()">Fechar</button>
    </div>
  </div>
</div>

<script>
let curStep=0,prompts=[],generated='',modalIdx=-1;
const STEPS=7;

function loadStorage(){
  try{const d=localStorage.getItem('maestro-prompts');if(d)prompts=JSON.parse(d);}catch(e){}
  renderLib();
}
function persist(){try{localStorage.setItem('maestro-prompts',JSON.stringify(prompts));}catch(e){}}

function goStep(n){
  document.getElementById('sp'+curStep).classList.remove('active');
  document.getElementById('stab'+curStep).classList.remove('active');
  curStep=n;
  document.getElementById('sp'+n).classList.add('active');
  document.getElementById('stab'+n).classList.add('active');
  updateNav();
  if(n===6)buildSummary();
}
function nextStep(){if(curStep<STEPS-1)goStep(curStep+1);}
function prevStep(){if(curStep>0)goStep(curStep-1);}
function updateNav(){
  document.getElementById('btn-prev').style.display=curStep>0?'':'none';
  document.getElementById('btn-next').style.display=curStep<STEPS-1?'':'none';
  document.getElementById('step-label').textContent=(curStep+1)+' / '+STEPS;
  for(let i=0;i<STEPS;i++)document.getElementById('p'+i).className='prog-seg'+(i<=curStep?' done':'');
  markFilled();
}
function markFilled(){
  const vals=[
    document.getElementById('f-missao').value,
    document.getElementById('f-ator').value,
    document.getElementById('f-tom').value||document.getElementById('f-estilo-custom').value,
    document.getElementById('f-situacao').value,
    document.getElementById('f-tarefas').value,
    document.getElementById('f-restricoes').value,
    document.getElementById('f-formato').value||document.getElementById('f-output-detail').value
  ];
  for(let i=0;i<STEPS;i++){
    const btn=document.getElementById('stab'+i);
    btn.className='step-btn'+(i===curStep?' active':vals[i].trim()?' filled':'');
  }
}
function addChip(id,btn){
  const el=document.getElementById(id);
  el.value=(el.value?el.value+'\n':'')+btn.textContent.trim();
  btn.classList.toggle('sel');
}
function setField(id,btn){
  document.getElementById(id).value=btn.textContent.trim();
  document.querySelectorAll('#sp1 .chip.sel').forEach(c=>c.classList.remove('sel'));
  btn.classList.add('sel');
}
function buildSummary(){
  const fields=[
    {l:'Missão',v:document.getElementById('f-missao').value},
    {l:'Ator',v:document.getElementById('f-ator').value},
    {l:'Estilo',v:[document.getElementById('f-tom').value,document.getElementById('f-estilo-custom').value].filter(Boolean).join(' · ')},
    {l:'Situação',v:document.getElementById('f-situacao').value},
    {l:'Tarefas',v:document.getElementById('f-tarefas').value},
    {l:'Restrições',v:document.getElementById('f-restricoes').value},
    {l:'Output',v:[document.getElementById('f-formato').value,document.getElementById('f-output-detail').value].filter(Boolean).join(' · ')}
  ];
  document.getElementById('summary-grid').innerHTML=fields.map(f=>`<div class="s-cell"><div class="s-cell-label">${f.l}</div><div class="s-cell-val">${f.v||'<span style="opacity:.4">—</span>'}</div></div>`).join('');
}
function buildUserPrompt(){
  const g=id=>document.getElementById(id).value.trim();
  const parts=['Você é um especialista em engenharia de prompts. Usando o framework MAESTRO, crie um prompt completo e pronto para uso:\n'];
  if(g('f-missao')) parts.push('M — Missão: '+g('f-missao'));
  if(g('f-ator')) parts.push('A — Ator: '+g('f-ator'));
  const e=[g('f-tom'),g('f-estilo-custom'),g('f-nivel')].filter(Boolean).join(' | ');
  if(e) parts.push('E — Estilo: '+e);
  if(g('f-situacao')) parts.push('S — Situação: '+g('f-situacao'));
  if(g('f-tarefas')) parts.push('T — Tarefas: '+g('f-tarefas'));
  if(g('f-restricoes')) parts.push('R — Restrições: '+g('f-restricoes'));
  const o=[g('f-formato'),g('f-output-detail')].filter(Boolean).join(' — ');
  if(o) parts.push('O — Output: '+o);
  parts.push('\nGere APENAS o prompt final, sem explicações adicionais.');
  return parts.join('\n');
}
function setStatus(msg,type){const el=document.getElementById('gen-status');el.innerHTML=msg;el.className='status '+(type||'');}
async function generatePrompt(){
  const btn=document.getElementById('btn-gen');
  btn.disabled=true;
  setStatus('<span class="spinner"></span>Gerando com Claude...','loading');
  generated='';
  document.getElementById('result-area').className='result-area';
  try{
    const resp=await fetch('https://api.anthropic.com/v1/messages',{
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body:JSON.stringify({model:'claude-sonnet-4-20250514',max_tokens:1000,messages:[{role:'user',content:buildUserPrompt()}]})
    });
    const data=await resp.json();
    const text=(data.content||[]).map(b=>b.text||'').join('').trim();
    if(!text)throw new Error();
    generated=text;
    document.getElementById('result-box').textContent=generated;
    document.getElementById('result-area').className='result-area show';
    setStatus('✓ Prompt gerado!','ok');
  }catch(e){setStatus('Erro ao gerar. Abra este arquivo dentro do Claude.ai.','err');}
  btn.disabled=false;
}
function saveGenerated(){
  if(!generated)return;
  const name=document.getElementById('f-nome').value.trim()||'Sem título';
  prompts.unshift({name,cat:document.getElementById('f-cat').value,prompt:generated,date:new Date().toLocaleDateString('pt-BR')});
  persist();renderLib();setStatus('✓ Salvo!','ok');
}
function saveRaw(){
  const name=document.getElementById('f-nome').value.trim()||'Sem título';
  prompts.unshift({name,cat:document.getElementById('f-cat').value,prompt:buildUserPrompt(),date:new Date().toLocaleDateString('pt-BR')});
  persist();renderLib();setStatus('✓ Estrutura salva!','ok');
}
function copyResult(){if(generated){navigator.clipboard.writeText(generated);setStatus('Copiado!','ok');}}
function renderLib(){
  const q=(document.getElementById('lib-search').value||'').toLowerCase();
  const f=prompts.filter(p=>p.name.toLowerCase().includes(q)||p.prompt.toLowerCase().includes(q));
  document.getElementById('lib-count').textContent=prompts.length+' prompt'+(prompts.length!==1?'s':'');
  const el=document.getElementById('lib-list');
  if(!f.length){el.innerHTML='<div class="empty">'+(prompts.length===0?'Nenhum prompt salvo ainda':'Nenhum resultado')+'</div>';return;}
  el.innerHTML=f.map((p)=>{
    const i=prompts.indexOf(p);
    return`<div class="pcard"><div class="pcard-top"><span class="pcard-name">${p.name}</span><span class="cat-badge">${p.cat}</span></div><div class="pcard-preview">${p.prompt}</div><div class="pcard-actions"><button class="mini" onclick="viewPrompt(${i})">Ver</button><button class="mini" onclick="copyPrompt(${i})">Copiar</button><button class="mini danger" onclick="deletePrompt(${i})">Excluir</button></div></div>`;
  }).join('');
}
function viewPrompt(i){modalIdx=i;document.getElementById('modal-title').textContent=prompts[i].name;document.getElementById('modal-body').textContent=prompts[i].prompt;document.getElementById('modal').className='modal-bg open';}
function closeModal(){document.getElementById('modal').className='modal-bg';}
function copyModal(){if(modalIdx>=0)navigator.clipboard.writeText(prompts[modalIdx].prompt);}
function copyPrompt(i){navigator.clipboard.writeText(prompts[i].prompt);setStatus('Copiado!','ok');}
function deletePrompt(i){if(!confirm('Remover "'+prompts[i].name+'"?'))return;prompts.splice(i,1);persist();renderLib();}

updateNav();
loadStorage();
</script>
